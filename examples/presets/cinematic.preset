[preset]
name = "cinematic"
description = "Cinematic color grading with enhanced contrast and vignette"
version = "1.0"

[[modules]]
name = "saturation"
[modules.uniforms]
u_saturation = "1.3"

[[modules]]
name = "contrast"
[modules.uniforms]
u_contrast = "1.4"

[[modules]]
name = "vignette"
[modules.uniforms]
u_strength = "0.4"
u_radius = "0.8"
