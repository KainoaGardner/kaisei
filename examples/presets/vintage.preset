[preset]
name = "vintage"
description = "Vintage film look with sepia tone and vignette"
version = "1.0"

[[modules]]
name = "sepia"
[modules.uniforms]
u_intensity = "0.8"

[[modules]]
name = "vignette"
[modules.uniforms]
u_strength = "0.6"
u_radius = "0.7"

[[modules]]
name = "contrast"
[modules.uniforms]
u_contrast = "1.2"
